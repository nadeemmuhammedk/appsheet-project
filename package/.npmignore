# .npmignore - Files to exclude from npm package
# Note: package.json "files" array is the primary whitelist
# This file serves as defense-in-depth

# Development files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Git files
.git/
.gitignore
.gitattributes

# Project-specific exclusions
.codex/
backups/
utils/
test-package.js
scripts/
PUBLISH.md

# Temporary files
*.tmp
*.temp
.temp/
.cache/

# Build artifacts (if any)
dist/
build/
*.tgz

# Testing files
test/
tests/
*.test.js
*.spec.js
coverage/
.nyc_output/

# Environment files
.env
.env.local
.env.*.local
*.env

# Lock files (not needed for library)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Documentation source (keep only compiled docs)
*.draft.md
*.wip.md

# Editor backup files
*~
\#*\#
.\#*
